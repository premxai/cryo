# Production environment variables for DigitalOcean deployment.
# Copy to droplet as /root/cryo/.env and fill in real values.
# NEVER commit this file — it's in .gitignore.

# ── Search ────────────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=change_me_strong_random_key_32chars

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:change_me@postgres:5432/cryo
POSTGRES_PASSWORD=change_me_strong_db_password

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:change_me@redis:6379
REDIS_PASSWORD=change_me_redis_password

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Domain / CORS ─────────────────────────────────────────────────────────────
DOMAIN=api.yourdomain.com
FRONTEND_URL=cryo.vercel.app
ALLOWED_ORIGINS=https://cryo.vercel.app,https://yourdomain.com

# ── GitHub (for pulling Docker image) ────────────────────────────────────────
GITHUB_REPO=premxai/cryo
