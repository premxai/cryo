# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic Claude API (used in M4 RLAIF judge)
ANTHROPIC_API_KEY=

# GPTZero AI detection API (used in M2 authenticity scoring)
GPTZERO_API_KEY=

# ── Search Infrastructure ──────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=cryo_dev_key

QDRANT_URL=http://localhost:6333

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:cryo@localhost:5432/cryo
REDIS_URL=redis://localhost:6379

# ── App Config ─────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# Embedding model name (sentence-transformers, used from M3)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_TTL_SECONDS=86400

# Claude model for AI judge (used from M4)
JUDGE_MODEL=claude-3-5-haiku-20241022
